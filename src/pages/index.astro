---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- ========== NAVBAR ========== -->
	<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="navbar">
		<div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
			<a href="#" class="font-serif-display text-xl tracking-[0.3em] uppercase text-white/90 hover:text-gold transition-colors duration-300">
				RC
			</a>
			<div class="hidden md:flex items-center gap-10">
				<a href="#sobre" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors duration-300">Sobre</a>
				<a href="#servicios" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors duration-300">Servicios</a>
				<a href="#portfolio" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors duration-300">Portfolio</a>
				<a href="#testimonios" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors duration-300">Testimonios</a>
				<a href="#contacto" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors duration-300">Contacto</a>
			</div>
			<a
				href="https://wa.me/523314061571?text=Hola%20Ricardo%2C%20me%20gustar%C3%ADa%20agendar%20una%20cita"
				target="_blank"
				rel="noopener noreferrer"
				class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 border border-gold/40 text-gold font-sans-thin text-xs tracking-[0.2em] uppercase hover:bg-gold/10 transition-all duration-300"
			>
				Agendar cita
			</a>
			<!-- Mobile menu button -->
			<button id="mobile-menu-btn" class="md:hidden text-white/70 hover:text-gold transition-colors" aria-label="Menú">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</div>
		<!-- Mobile menu -->
		<div id="mobile-menu" class="md:hidden hidden bg-[#0a0a0a]/95 backdrop-blur-md border-t border-white/5">
			<div class="px-6 py-6 flex flex-col gap-5">
				<a href="#sobre" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors">Sobre</a>
				<a href="#servicios" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors">Servicios</a>
				<a href="#portfolio" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors">Portfolio</a>
				<a href="#testimonios" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors">Testimonios</a>
				<a href="#contacto" class="font-sans-thin text-sm tracking-[0.15em] uppercase text-white/60 hover:text-gold transition-colors">Contacto</a>
				<a
					href="https://wa.me/523314061571?text=Hola%20Ricardo%2C%20me%20gustar%C3%ADa%20agendar%20una%20cita"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center gap-2 px-5 py-3 border border-gold/40 text-gold font-sans-thin text-xs tracking-[0.2em] uppercase hover:bg-gold/10 transition-all"
				>
					Agendar cita
				</a>
			</div>
		</div>
	</nav>

	<!-- ========== HERO ========== -->
	<section class="relative min-h-screen flex items-center justify-center overflow-hidden vignette">
		<!-- Background gradient -->
		<div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-[#0f0e0a] to-[#0a0a0a]"></div>
		<!-- Subtle radial accent -->
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(201,168,76,0.04)_0%,_transparent_70%)]"></div>

		<div class="relative z-10 text-center px-6 py-32">
			<!-- Top decorative line -->
			<div class="w-12 h-px bg-gold/40 mx-auto mb-12 animate-[revealLine_1.5s_ease-out_0.3s_both] origin-center"></div>

			<!-- Name -->
			<h1 class="animate-[fadeIn_2s_ease-out_0.5s_both]">
				<span class="block font-serif-display text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-light tracking-[0.25em] sm:tracking-[0.35em] uppercase text-white leading-none">
					Ricardo
				</span>
				<span class="block font-serif-display text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-light tracking-[0.25em] sm:tracking-[0.35em] uppercase text-white leading-none mt-2">
					Camacho
				</span>
			</h1>

			<!-- SALÓN -->
			<p class="animate-[fadeIn_2s_ease-out_1s_both] mt-6 font-sans-thin text-lg sm:text-xl tracking-[0.5em] uppercase text-gold/70 font-extralight">
				Salón
			</p>

			<!-- Subtitle -->
			<p class="animate-[fadeIn_2s_ease-out_1.4s_both] mt-8 font-sans-thin text-sm sm:text-base tracking-[0.2em] text-white/40 font-extralight">
				Estilismo con firma personal · Guadalajara
			</p>

			<!-- Reviews badge -->
			<div class="animate-[fadeInUp_1.5s_ease-out_1.8s_both] mt-10 inline-flex items-center gap-3 px-6 py-3 border border-white/10 bg-white/[0.02] backdrop-blur-sm">
				<div class="flex gap-0.5 text-gold">
					<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M10 1l2.39 6.17H19l-5.3 4.07L15.82 18 10 13.93 4.18 18l2.12-6.76L1 7.17h6.61z"/></svg>
					<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M10 1l2.39 6.17H19l-5.3 4.07L15.82 18 10 13.93 4.18 18l2.12-6.76L1 7.17h6.61z"/></svg>
					<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M10 1l2.39 6.17H19l-5.3 4.07L15.82 18 10 13.93 4.18 18l2.12-6.76L1 7.17h6.61z"/></svg>
					<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M10 1l2.39 6.17H19l-5.3 4.07L15.82 18 10 13.93 4.18 18l2.12-6.76L1 7.17h6.61z"/></svg>
					<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20"><path d="M10 1l2.39 6.17H19l-5.3 4.07L15.82 18 10 13.93 4.18 18l2.12-6.76L1 7.17h6.61z"/></svg>
				</div>
				<span class="font-sans-thin text-xs tracking-[0.15em] text-white/50">5.0 · 69 reseñas</span>
			</div>

			<!-- CTA -->
			<div class="animate-[fadeInUp_1.5s_ease-out_2.2s_both] mt-12">
				<a
					href="https://wa.me/523314061571?text=Hola%20Ricardo%2C%20me%20gustar%C3%ADa%20agendar%20una%20cita"
					target="_blank"
					rel="noopener noreferrer"
					class="group inline-flex items-center gap-3 px-10 py-4 bg-gold/10 border border-gold/30 text-gold font-sans-thin text-sm tracking-[0.25em] uppercase hover:bg-gold/20 hover:border-gold/50 transition-all duration-500"
				>
					Agenda tu cita con Ricardo
					<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
					</svg>
				</a>
			</div>

			<!-- Scroll indicator -->
			<div class="animate-[fadeIn_2s_ease-out_3s_both] mt-20">
				<div class="w-px h-16 bg-gradient-to-b from-transparent via-gold/30 to-transparent mx-auto animate-pulse"></div>
			</div>
		</div>
	</section>

	<!-- ========== SOBRE RICARDO ========== -->
	<section id="sobre" class="relative py-24 md:py-32 overflow-hidden">
		<!-- Background -->
		<div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-surface to-[#0a0a0a]"></div>

		<div class="relative z-10 max-w-7xl mx-auto px-6">
			<!-- Section label -->
			<div class="fade-in-up mb-16 md:mb-24">
				<span class="font-sans-thin text-[10px] tracking-[0.4em] uppercase text-gold/50">01 — Sobre</span>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-0 items-center">
				<!-- Photo - large, dominant -->
				<div class="fade-in-up lg:col-span-7 relative">
					<div class="relative aspect-[3/4] max-h-[700px] overflow-hidden">
						<img
							src="https://images.unsplash.com/photo-1622287162716-f311baa1a2b8?w=800&h=1100&fit=crop&crop=top"
							alt="Ricardo Camacho — Estilista profesional"
							class="w-full h-full object-cover grayscale-[30%] contrast-[1.05]"
							loading="lazy"
						/>
						<!-- Photo overlay gradient -->
						<div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-[#0a0a0a]/80 lg:block hidden"></div>
						<div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a]/60 via-transparent to-transparent"></div>
					</div>
					<!-- Decorative frame -->
					<div class="absolute -bottom-4 -right-4 w-full h-full border border-gold/10 -z-10 hidden lg:block"></div>
				</div>

				<!-- Text - overlapping photo on desktop -->
				<div class="fade-in-up lg:col-span-6 lg:-ml-20 relative z-10 lg:col-start-7">
					<div class="lg:bg-[#0a0a0a]/90 lg:backdrop-blur-sm lg:p-12 lg:border lg:border-white/5">
						<h2 class="font-serif-display text-4xl md:text-5xl lg:text-6xl font-light tracking-[0.15em] uppercase text-white mb-2">
							Ricardo
						</h2>
						<h2 class="font-serif-display text-4xl md:text-5xl lg:text-6xl font-light tracking-[0.15em] uppercase text-white/60 mb-8">
							Camacho
						</h2>
						<div class="w-12 h-px bg-gold/40 mb-8"></div>
						<p class="font-sans-thin text-base md:text-lg leading-relaxed text-white/50 font-extralight mb-6">
							Cada cabello cuenta una historia. Mi trabajo es ayudarte a contar la tuya con estilo, personalidad y confianza.
						</p>
						<p class="font-sans-thin text-base md:text-lg leading-relaxed text-white/50 font-extralight">
							Con años de experiencia y una obsesión por el detalle, cada visita a mi salón es una experiencia única.
						</p>
						<div class="mt-10 flex items-center gap-6">
							<div class="text-center">
								<span class="block font-serif-display text-3xl text-gold">69</span>
								<span class="font-sans-thin text-[10px] tracking-[0.2em] uppercase text-white/30">Reseñas</span>
							</div>
							<div class="w-px h-10 bg-white/10"></div>
							<div class="text-center">
								<span class="block font-serif-display text-3xl text-gold">5.0</span>
								<span class="font-sans-thin text-[10px] tracking-[0.2em] uppercase text-white/30">Estrellas</span>
							</div>
							<div class="w-px h-10 bg-white/10"></div>
							<div class="text-center">
								<span class="block font-serif-display text-3xl text-gold">GDL</span>
								<span class="font-sans-thin text-[10px] tracking-[0.2em] uppercase text-white/30">Ubicación</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ========== SERVICIOS ========== -->
	<section id="servicios" class="relative py-24 md:py-32">
		<div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-[#0d0d0b] to-[#0a0a0a]"></div>
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(201,168,76,0.02)_0%,_transparent_60%)]"></div>

		<div class="relative z-10 max-w-5xl mx-auto px-6">
			<!-- Section label -->
			<div class="fade-in-up mb-6">
				<span class="font-sans-thin text-[10px] tracking-[0.4em] uppercase text-gold/50">02 — Servicios</span>
			</div>
			<h2 class="fade-in-up font-serif-display text-4xl md:text-5xl font-light tracking-[0.12em] uppercase text-white mb-4">
				Servicios
			</h2>
			<p class="fade-in-up font-sans-thin text-sm tracking-[0.1em] text-white/30 font-extralight mb-16 md:mb-20">
				Cada servicio es personalizado a tu estilo y necesidades
			</p>

			<!-- Services grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-0">
				<!-- Service 1 -->
				<div class="fade-in-up group border-t border-white/[0.06] py-10 px-6 md:border-r hover:bg-white/[0.015] transition-all duration-500">
					<div class="flex items-start justify-between">
						<div>
							<span class="font-sans-thin text-[10px] tracking-[0.3em] text-gold/40 uppercase">01</span>
							<h3 class="font-serif-display text-2xl font-light tracking-[0.08em] text-white mt-3 group-hover:text-gold/90 transition-colors duration-500">Corte Personalizado</h3>
							<p class="font-sans-thin text-xs tracking-wider text-white/25 mt-2 font-extralight">Diseñado para tu rostro y estilo de vida</p>
						</div>
						<svg class="w-5 h-5 text-gold/20 group-hover:text-gold/50 transition-colors mt-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</div>

				<!-- Service 2 -->
				<div class="fade-in-up group border-t border-white/[0.06] py-10 px-6 hover:bg-white/[0.015] transition-all duration-500">
					<div class="flex items-start justify-between">
						<div>
							<span class="font-sans-thin text-[10px] tracking-[0.3em] text-gold/40 uppercase">02</span>
							<h3 class="font-serif-display text-2xl font-light tracking-[0.08em] text-white mt-3 group-hover:text-gold/90 transition-colors duration-500">Colorimetría Avanzada</h3>
							<p class="font-sans-thin text-xs tracking-wider text-white/25 mt-2 font-extralight">Color preciso y duradero con técnicas profesionales</p>
						</div>
						<svg class="w-5 h-5 text-gold/20 group-hover:text-gold/50 transition-colors mt-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</div>

				<!-- Service 3 -->
				<div class="fade-in-up group border-t border-white/[0.06] py-10 px-6 md:border-r hover:bg-white/[0.015] transition-all duration-500">
					<div class="flex items-start justify-between">
						<div>
							<span class="font-sans-thin text-[10px] tracking-[0.3em] text-gold/40 uppercase">03</span>
							<h3 class="font-serif-display text-2xl font-light tracking-[0.08em] text-white mt-3 group-hover:text-gold/90 transition-colors duration-500">Mechas y Balayage</h3>
							<p class="font-sans-thin text-xs tracking-wider text-white/25 mt-2 font-extralight">Iluminación natural con técnica a mano alzada</p>
						</div>
						<svg class="w-5 h-5 text-gold/20 group-hover:text-gold/50 transition-colors mt-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</div>

				<!-- Service 4 -->
				<div class="fade-in-up group border-t border-white/[0.06] py-10 px-6 hover:bg-white/[0.015] transition-all duration-500">
					<div class="flex items-start justify-between">
						<div>
							<span class="font-sans-thin text-[10px] tracking-[0.3em] text-gold/40 uppercase">04</span>
							<h3 class="font-serif-display text-2xl font-light tracking-[0.08em] text-white mt-3 group-hover:text-gold/90 transition-colors duration-500">Tratamientos Reconstructivos</h3>
							<p class="font-sans-thin text-xs tracking-wider text-white/25 mt-2 font-extralight">Restauración profunda de la fibra capilar</p>
						</div>
						<svg class="w-5 h-5 text-gold/20 group-hover:text-gold/50 transition-colors mt-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</div>

				<!-- Service 5 -->
				<div class="fade-in-up group border-t border-white/[0.06] py-10 px-6 md:border-r hover:bg-white/[0.015] transition-all duration-500">
					<div class="flex items-start justify-between">
						<div>
							<span class="font-sans-thin text-[10px] tracking-[0.3em] text-gold/40 uppercase">05</span>
							<h3 class="font-serif-display text-2xl font-light tracking-[0.08em] text-white mt-3 group-hover:text-gold/90 transition-colors duration-500">Alisados Premium</h3>
							<p class="font-sans-thin text-xs tracking-wider text-white/25 mt-2 font-extralight">Cabello liso, brillante y sin daño</p>
						</div>
						<svg class="w-5 h-5 text-gold/20 group-hover:text-gold/50 transition-colors mt-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</div>

				<!-- Service 6 -->
				<div class="fade-in-up group border-t border-b border-white/[0.06] py-10 px-6 hover:bg-white/[0.015] transition-all duration-500">
					<div class="flex items-start justify-between">
						<div>
							<span class="font-sans-thin text-[10px] tracking-[0.3em] text-gold/40 uppercase">06</span>
							<h3 class="font-serif-display text-2xl font-light tracking-[0.08em] text-white mt-3 group-hover:text-gold/90 transition-colors duration-500">Peinados para Eventos</h3>
							<p class="font-sans-thin text-xs tracking-wider text-white/25 mt-2 font-extralight">Looks memorables para ocasiones especiales</p>
						</div>
						<svg class="w-5 h-5 text-gold/20 group-hover:text-gold/50 transition-colors mt-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ========== PORTFOLIO ========== -->
	<section id="portfolio" class="relative py-24 md:py-32">
		<div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-surface to-[#0a0a0a]"></div>

		<div class="relative z-10 max-w-7xl mx-auto px-6">
			<!-- Section label -->
			<div class="fade-in-up mb-6">
				<span class="font-sans-thin text-[10px] tracking-[0.4em] uppercase text-gold/50">03 — Portfolio</span>
			</div>
			<h2 class="fade-in-up font-serif-display text-4xl md:text-5xl font-light tracking-[0.12em] uppercase text-white mb-4">
				Mi Trabajo
			</h2>
			<p class="fade-in-up font-sans-thin text-sm tracking-[0.1em] text-white/30 font-extralight mb-16 md:mb-20">
				Algunos de mis trabajos recientes de color, corte y transformación
			</p>

			<!-- Portfolio grid -->
			<div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
				<div class="fade-in-up group relative aspect-[3/4] overflow-hidden cursor-pointer">
					<img
						src="https://images.unsplash.com/photo-1605497788044-5a32c7078486?w=600&h=800&fit=crop"
						alt="Balayage rubio natural"
						class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					<div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
						<span class="font-sans-thin text-xs tracking-[0.15em] text-gold uppercase">Balayage</span>
					</div>
				</div>

				<div class="fade-in-up group relative aspect-[3/4] overflow-hidden cursor-pointer">
					<img
						src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&h=800&fit=crop"
						alt="Mechas caramelo"
						class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					<div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
						<span class="font-sans-thin text-xs tracking-[0.15em] text-gold uppercase">Mechas</span>
					</div>
				</div>

				<div class="fade-in-up group relative aspect-[3/4] overflow-hidden cursor-pointer">
					<img
						src="https://images.unsplash.com/photo-1620331311520-246422fd82f9?w=600&h=800&fit=crop"
						alt="Corte creativo bob"
						class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					<div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
						<span class="font-sans-thin text-xs tracking-[0.15em] text-gold uppercase">Corte creativo</span>
					</div>
				</div>

